# PostgreSQL connection string used by app/config.py.
# The app will convert postgresql:// to postgresql+asyncpg:// internally for async DB access.
DATABASE_URL=postgresql://postgres:password@localhost:5432/vectorx

# JWT-related settings. These are configured in the app even though token issuance is not fully wired yet.
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis connection for background jobs / RQ worker support.
REDIS_URL=redis://localhost:6379

# S3 or MinIO document storage settings.
S3_BUCKET=vectorx-documents

# Leave empty for AWS S3, or set a custom endpoint for MinIO/S3-compatible storage.
S3_ENDPOINT=

# AWS or MinIO credentials/region.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
